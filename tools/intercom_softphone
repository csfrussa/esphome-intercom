#!/usr/bin/env python3
"""SIP/RTP softphone for ESPHome intercom development.

Examples:
  tools/intercom_softphone -call -name bench -address 192.168.1.47 -port 5060 -send tone -receive-file /tmp/rx.wav -log-file /tmp/sip.log
  tools/intercom_softphone --call --transport tcp --name ha-test --address 192.168.1.10 --target kitchen --send-wav /tmp/send.wav --receive-file /tmp/rx.wav
  tools/intercom_softphone --options --address 192.168.1.47 --port 5060
"""

from __future__ import annotations

import argparse
import asyncio
import contextlib
import importlib.util
import logging
import math
import os
from pathlib import Path
import socket
import struct
import sys
import time
import wave


ROOT = Path(__file__).resolve().parents[1]
PKG_DIR = ROOT / "custom_components" / "intercom_native"
PKG_NAME = "custom_components.intercom_native"


def _load_intercom_module(name: str):
    if "custom_components" not in sys.modules:
        pkg = type(sys)("custom_components")
        pkg.__path__ = [str(ROOT / "custom_components")]
        sys.modules["custom_components"] = pkg
    if PKG_NAME not in sys.modules:
        pkg = type(sys)(PKG_NAME)
        pkg.__path__ = [str(PKG_DIR)]
        sys.modules[PKG_NAME] = pkg
    full_name = f"{PKG_NAME}.{name}"
    spec = importlib.util.spec_from_file_location(full_name, PKG_DIR / f"{name}.py")
    if spec is None or spec.loader is None:
        raise RuntimeError(f"cannot load {full_name}")
    module = importlib.util.module_from_spec(spec)
    sys.modules[full_name] = module
    spec.loader.exec_module(module)
    return module


audio_format_mod = _load_intercom_module("audio_format")
rtp_mod = _load_intercom_module("rtp")
sdp_mod = _load_intercom_module("sdp")
sip_mod = _load_intercom_module("sip")
sip_client_mod = _load_intercom_module("sip_client")

AudioFormat = audio_format_mod.AudioFormat
PcmFormat = audio_format_mod.PcmFormat
parse_audio_format_token = audio_format_mod.parse_audio_format_token
SipCallClient = sip_client_mod.SipCallClient
pcm_to_rtp_payload = sip_client_mod.pcm_to_rtp_payload
rtp_payload_to_pcm = sip_client_mod.rtp_payload_to_pcm

LOG = logging.getLogger("intercom_softphone")
DEFAULT_FORMAT = AudioFormat(16000, PcmFormat.S16LE, 1, 20)


def _local_ip_for(remote_host: str) -> str:
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        sock.connect((remote_host, 9))
        return str(sock.getsockname()[0])
    finally:
        sock.close()


def _sample_width(fmt: AudioFormat) -> int:
    if fmt.pcm_format == PcmFormat.S16LE:
        return 2
    if fmt.pcm_format == PcmFormat.S24LE:
        return 3
    if fmt.pcm_format == PcmFormat.S24LE_IN_S32:
        return 4
    raise ValueError(f"{fmt.pcm_format.value} is not a supported softphone PCM format")


def _tone_frame(fmt: AudioFormat, freq: float, phase: float) -> tuple[bytes, float]:
    samples = fmt.nominal_frame_samples
    rate = float(fmt.sample_rate)
    amp16 = 0.28 * 32767.0
    amp24 = 0.28 * 8388607.0
    out = bytearray()
    for i in range(samples):
        v = math.sin(phase + (2.0 * math.pi * freq * i / rate))
        if fmt.pcm_format == PcmFormat.S16LE:
            out.extend(struct.pack("<h", int(v * amp16)))
        elif fmt.pcm_format == PcmFormat.S24LE:
            sample = int(v * amp24)
            out.extend(int(sample).to_bytes(3, "little", signed=True))
        elif fmt.pcm_format == PcmFormat.S24LE_IN_S32:
            sample = int(v * amp24)
            out.extend(struct.pack("<i", sample << 8))
        else:
            raise ValueError(f"unsupported tone format {fmt.pcm_format.value}")
    phase = (phase + (2.0 * math.pi * freq * samples / rate)) % (2.0 * math.pi)
    return bytes(out), phase


def _wav_frames(path: Path, fmt: AudioFormat) -> list[bytes]:
    with wave.open(str(path), "rb") as wav:
        if wav.getframerate() != fmt.sample_rate:
            raise ValueError(f"{path} sample_rate {wav.getframerate()} != negotiated {fmt.sample_rate}")
        if wav.getnchannels() != fmt.channels:
            raise ValueError(f"{path} channels {wav.getnchannels()} != negotiated {fmt.channels}")
        if wav.getsampwidth() != _sample_width(fmt):
            raise ValueError(f"{path} sample width {wav.getsampwidth()} != negotiated {_sample_width(fmt)}")
        frame_samples = fmt.nominal_frame_samples
        frames: list[bytes] = []
        while True:
            data = wav.readframes(frame_samples)
            if not data:
                break
            expected = fmt.nominal_frame_bytes
            if len(data) < expected:
                data += b"\x00" * (expected - len(data))
            frames.append(data)
        return frames


class RtpSoftphone:
    def __init__(
        self,
        *,
        local_port: int,
        remote_host: str,
        remote_port: int,
        send_format: AudioFormat,
        recv_format: AudioFormat,
        send_payload_type: int,
        recv_payload_type: int,
        receive_file: Path | None,
    ) -> None:
        self.local_port = int(local_port)
        self.remote_host = remote_host
        self.remote_port = int(remote_port)
        self.send_format = send_format
        self.recv_format = recv_format
        self.send_payload_type = int(send_payload_type)
        self.recv_payload_type = int(recv_payload_type)
        self.receive_file = receive_file
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.sock.setblocking(False)
        self.sock.bind(("0.0.0.0", self.local_port))
        self.sequence = int(time.time() * 1000) & 0xFFFF
        self.timestamp = int(time.time() * 1000) & 0xFFFFFFFF
        self.ssrc = os.getpid() & 0xFFFFFFFF
        self.tx_packets = 0
        self.tx_bytes = 0
        self.rx_packets = 0
        self.rx_bytes = 0
        self.dropped = 0
        self._wav: wave.Wave_write | None = None
        if receive_file is not None:
            receive_file.parent.mkdir(parents=True, exist_ok=True)
            self._wav = wave.open(str(receive_file), "wb")
            self._wav.setnchannels(self.recv_format.channels)
            self._wav.setsampwidth(_sample_width(self.recv_format))
            self._wav.setframerate(self.recv_format.sample_rate)

    def close(self) -> None:
        if self._wav is not None:
            self._wav.close()
            self._wav = None
        self.sock.close()

    async def send_pcm(self, pcm: bytes) -> None:
        payload = pcm_to_rtp_payload(pcm, self.send_format)
        packet = rtp_mod.build_packet(
            rtp_mod.RtpPacket(
                payload_type=self.send_payload_type,
                sequence=self.sequence,
                timestamp=self.timestamp,
                ssrc=self.ssrc,
                payload=payload,
            )
        )
        sent = self.sock.sendto(packet, (self.remote_host, self.remote_port))
        self.tx_packets += 1
        self.tx_bytes += sent
        self.sequence = rtp_mod.next_sequence(self.sequence)
        self.timestamp = rtp_mod.next_timestamp(self.timestamp, self.send_format.nominal_frame_samples)

    async def recv_loop(self, stop: asyncio.Event) -> None:
        loop = asyncio.get_running_loop()
        while not stop.is_set():
            try:
                data, addr = await loop.sock_recvfrom(self.sock, 2048)
            except (OSError, asyncio.CancelledError):
                return
            if addr[0] != self.remote_host or int(addr[1]) != self.remote_port:
                self.dropped += 1
                continue
            try:
                packet = rtp_mod.parse_packet(data)
                if packet.payload_type != self.recv_payload_type:
                    raise ValueError(f"payload type {packet.payload_type} != {self.recv_payload_type}")
                pcm = rtp_payload_to_pcm(packet.payload, self.recv_format)
            except Exception as err:
                self.dropped += 1
                LOG.debug("RTP drop from %s:%s: %s", addr[0], addr[1], err)
                continue
            self.rx_packets += 1
            self.rx_bytes += len(data)
            if self._wav is not None:
                self._wav.writeframesraw(pcm)


async def _send_media(args: argparse.Namespace, rtp_phone: RtpSoftphone, stop: asyncio.Event) -> None:
    interval = max(0.001, rtp_phone.send_format.frame_ms / 1000.0)
    deadline = time.monotonic() + float(args.duration)
    if args.send_wav:
        frames = _wav_frames(Path(args.send_wav), rtp_phone.send_format)
        while frames and not stop.is_set() and time.monotonic() < deadline:
            for frame in frames:
                if stop.is_set() or time.monotonic() >= deadline:
                    break
                await rtp_phone.send_pcm(frame)
                await asyncio.sleep(interval)
        return
    if args.send == "none":
        await asyncio.sleep(max(0.0, deadline - time.monotonic()))
        return
    phase = 0.0
    while not stop.is_set() and time.monotonic() < deadline:
        pcm, phase = _tone_frame(rtp_phone.send_format, float(args.tone), phase)
        await rtp_phone.send_pcm(pcm)
        await asyncio.sleep(interval)


async def _send_options(args: argparse.Namespace) -> int:
    host = args.address
    port = int(args.port)
    local_ip = _local_ip_for(host)
    call_id = sip_mod.make_call_id("tool")
    branch = sip_mod.make_branch()
    target = args.target or args.name or "intercom"
    transport = args.transport.upper()
    request_uri = str(sip_mod.SipUri(target, host, port, params=(("transport", args.transport),)))
    local_uri = str(sip_mod.SipUri(args.name, local_ip, int(args.local_sip_port), params=(("transport", args.transport),)))
    dialog = sip_mod.SipDialogIds(call_id=call_id, local_tag=sip_mod.make_tag(), branch=branch)
    headers = sip_mod.dialog_headers(
        request_uri=request_uri,
        local_uri=local_uri,
        remote_uri=request_uri,
        dialog=dialog,
        method="OPTIONS",
        contact_uri=local_uri,
        transport=transport,
    )
    raw = sip_mod.build_request("OPTIONS", request_uri, headers, b"")
    if transport == "TCP":
        reader, writer = await asyncio.open_connection(host, port)
        writer.write(raw)
        await writer.drain()
        response = await sip_client_mod._read_sip_stream_message(reader)
        writer.close()
        with contextlib.suppress(Exception):
            await writer.wait_closed()
    else:
        sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        sock.settimeout(float(args.timeout))
        sock.sendto(raw, (host, port))
        response, _addr = sock.recvfrom(4096)
        sock.close()
    msg = sip_mod.parse_message(response)
    LOG.info("OPTIONS result: %s %s", msg.status_code, msg.reason)
    print(f"{msg.status_code} {msg.reason}")
    return 0 if msg.status_code and 200 <= msg.status_code < 300 else 2


async def _call(args: argparse.Namespace) -> int:
    host = args.address
    port = int(args.port)
    local_ip = _local_ip_for(host)
    target = args.target or args.name
    formats = [parse_audio_format_token(token) for token in args.format]
    client = SipCallClient(
        local_ip=local_ip,
        local_name=args.name,
        local_sip_port=int(args.local_sip_port),
        local_rtp_port=int(args.local_rtp_port),
        supported_send_formats=formats,
        supported_recv_formats=formats,
        signaling_transport=args.transport.upper(),
    )
    try:
        LOG.info("Calling sip:%s@%s:%s transport=%s local_rtp=%s", target, host, port, args.transport, args.local_rtp_port)
        result = await client.invite(target=target, remote_host=host, remote_sip_port=port, timeout=float(args.timeout))
        if result == "ringing":
            LOG.info("Remote ringing, waiting for final response")
            result = await client.wait_for_final(timeout=float(args.final_timeout))
        if result != "in_call" or client.dialog is None:
            LOG.info("Call ended before media: %s snapshot=%s", result, client.snapshot())
            print(result)
            return 2
        dialog = client.dialog
        send_fmt = dialog.send_format.audio_format
        recv_fmt = dialog.recv_format.audio_format
        LOG.info(
            "Call established call_id=%s remote_rtp=%s:%s tx=%s rx=%s",
            dialog.call_id,
            dialog.remote_rtp_host,
            dialog.remote_rtp_port,
            send_fmt.wire_token(),
            recv_fmt.wire_token(),
        )
        rtp_phone = RtpSoftphone(
            local_port=int(args.local_rtp_port),
            remote_host=dialog.remote_rtp_host,
            remote_port=dialog.remote_rtp_port,
            send_format=send_fmt,
            recv_format=recv_fmt,
            send_payload_type=dialog.send_format.payload_type,
            recv_payload_type=dialog.recv_format.payload_type,
            receive_file=Path(args.receive_file) if args.receive_file else None,
        )
        stop = asyncio.Event()
        recv_task = asyncio.create_task(rtp_phone.recv_loop(stop))
        try:
            await _send_media(args, rtp_phone, stop)
        finally:
            stop.set()
            recv_task.cancel()
            with contextlib.suppress(Exception):
                await recv_task
            LOG.info(
                "RTP summary tx_packets=%s tx_bytes=%s rx_packets=%s rx_bytes=%s dropped=%s",
                rtp_phone.tx_packets,
                rtp_phone.tx_bytes,
                rtp_phone.rx_packets,
                rtp_phone.rx_bytes,
                rtp_phone.dropped,
            )
            rtp_phone.close()
        client.bye()
        print("in_call")
        return 0
    finally:
        await client.close()


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="SIP/RTP intercom softphone")
    parser.add_argument("-call", "--call", action="store_true", help="place an outbound SIP INVITE")
    parser.add_argument("--options", action="store_true", help="send SIP OPTIONS instead of a call")
    parser.add_argument("-name", "--name", default="intercom_softphone", help="local SIP user/display name")
    parser.add_argument("--target", default="", help="remote SIP user; defaults to --name")
    parser.add_argument("-address", "--address", required=True, help="remote ESP/HA SIP host")
    parser.add_argument("-port", "--port", type=int, default=5060, help="remote SIP port")
    parser.add_argument("--transport", choices=("udp", "tcp"), default="udp", help="SIP signaling transport")
    parser.add_argument("--local-sip-port", type=int, default=5062, help="local SIP port advertised in Contact")
    parser.add_argument("--local-rtp-port", type=int, default=40002, help="local RTP UDP port")
    parser.add_argument("-send", "--send", choices=("tone", "none"), default="tone", help="media source")
    parser.add_argument("--send-wav", default="", help="WAV file to transmit instead of generated tone")
    parser.add_argument("--tone", type=float, default=880.0, help="tone frequency in Hz")
    parser.add_argument("-receive-file", "--receive-file", default="", help="write received RTP audio to this WAV")
    parser.add_argument("-log-file", "--log-file", default="", help="write SIP/RTP backlog to this log file")
    parser.add_argument("--duration", type=float, default=10.0, help="media duration before BYE")
    parser.add_argument("--timeout", type=float, default=8.0, help="initial INVITE/OPTIONS timeout")
    parser.add_argument("--final-timeout", type=float, default=60.0, help="time to wait after 180 Ringing")
    parser.add_argument(
        "--format",
        action="append",
        default=[],
        help="supported PCM token, e.g. 16000:s16le:1:20; repeatable",
    )
    return parser


def _configure_logging(path: str) -> None:
    handlers: list[logging.Handler] = [logging.StreamHandler()]
    if path:
        log_path = Path(path)
        log_path.parent.mkdir(parents=True, exist_ok=True)
        handlers.append(logging.FileHandler(log_path, encoding="utf-8"))
    logging.basicConfig(
        level=logging.DEBUG,
        format="%(asctime)s %(levelname)s %(name)s: %(message)s",
        handlers=handlers,
    )


async def _amain() -> int:
    parser = _build_parser()
    args = parser.parse_args()
    _configure_logging(args.log_file)
    if args.send_wav:
        args.send = "tone"
    if not args.format:
        args.format = [DEFAULT_FORMAT.wire_token()]
    try:
        if args.options:
            return await _send_options(args)
        if args.call:
            return await _call(args)
        parser.error("select -call/--call or --options")
    except KeyboardInterrupt:
        return 130


def main() -> None:
    raise SystemExit(asyncio.run(_amain()))


if __name__ == "__main__":
    main()
