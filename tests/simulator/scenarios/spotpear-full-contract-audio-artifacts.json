{
  "name": "spotpear-full-contract-audio-artifacts",
  "description": "Spotpear contract profile exposes virtual mic input, writes speaker/audio artifacts, and reports audio counters in the simulator snapshot.",
  "steps": [
    {
      "expect": {
        "runtime": {
          "device_profile": "spotpear_ball_v2_full_afe",
          "source_profile": "yamls/full-experience/single-bus/spotpear-ball-v2-full-afe.yaml"
        },
        "audio": {
          "mic_input_path": "tests/simulator/audio/mic_input.pcm",
          "mic_input_bytes": 80000,
          "speaker_output_path": "test_runs/simulator/spotpear-voip-contract_speaker_output.pcm",
          "speaker_output_bytes": 0
        }
      }
    },
    {
      "inject_event": {
        "type": "browser_audio_ready"
      }
    },
    {
      "expect": {
        "audio": {
          "tx_ready": true,
          "rx_ready": true,
          "tx_frames": 1,
          "speaker_output_bytes": 35
        }
      }
    },
    {
      "expect_file": {
        "path": "test_runs/simulator/spotpear-voip-contract_speaker_output.pcm",
        "min_bytes": 35,
        "contains": "browser_audio_ready"
      }
    },
    {
      "inject_pcm": true
    },
    {
      "expect": {
        "audio": {
          "tx_frames": 2,
          "speaker_output_bytes": 61
        }
      }
    },
    {
      "expect_file": {
        "path": "test_runs/simulator/spotpear-voip-contract_speaker_output.pcm",
        "min_bytes": 61,
        "contains": "inject_pcm"
      }
    }
  ]
}
