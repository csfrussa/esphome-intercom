{
  "name": "esp-to-ha-busy-while-streaming",
  "description": "Second ESP calling HA while HA softphone is streaming receives Busy.",
  "steps": [
    {
      "inject_event": {
        "type": "esp_call",
        "source": "Virtual S3",
        "destination": "Casa"
      }
    },
    {
      "inject_event": {
        "type": "browser_audio_ready",
        "call_id": "Virtual S3<->Casa"
      }
    },
    {
      "press_button": "answer"
    },
    {
      "expect": {
        "softphone": {
          "state": "streaming"
        }
      }
    },
    {
      "inject_event": {
        "type": "esp_call",
        "source": "Virtual Spotpear",
        "destination": "Casa"
      }
    },
    {
      "expect": {
        "second": {
          "state": "idle",
          "last_reason": "busy"
        },
        "softphone": {
          "state": "streaming"
        }
      }
    }
  ]
}
