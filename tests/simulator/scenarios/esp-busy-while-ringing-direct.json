{
  "name": "esp-busy-while-ringing-direct",
  "description": "ESP already ringing from HA rejects a direct second ESP call.",
  "steps": [
    {
      "inject_event": {
        "type": "ha_call",
        "target": "Virtual S3",
        "caller": "Casa"
      }
    },
    {
      "expect": {
        "esp": {
          "state": "ringing",
          "caller": "Casa"
        }
      }
    },
    {
      "inject_event": {
        "type": "esp_call",
        "source": "Virtual Spotpear",
        "destination": "Virtual S3",
        "route": "direct"
      }
    },
    {
      "expect": {
        "second": {
          "state": "idle",
          "last_reason": "busy"
        },
        "esp": {
          "state": "ringing",
          "caller": "Casa"
        }
      }
    }
  ]
}
