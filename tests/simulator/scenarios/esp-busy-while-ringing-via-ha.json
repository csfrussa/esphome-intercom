{
  "name": "esp-busy-while-ringing-via-ha",
  "description": "ESP already ringing from HA rejects a second ESP call routed through HA.",
  "steps": [
    {
      "inject_event": {
        "type": "ha_call",
        "target": "Virtual S3",
        "caller": "Casa"
      }
    },
    {
      "inject_event": {
        "type": "esp_call",
        "source": "Virtual Spotpear",
        "destination": "Virtual S3",
        "route": "bridge"
      }
    },
    {
      "expect": {
        "second": {
          "state": "idle",
          "last_reason": "busy"
        },
        "bridge": {
          "state": "idle"
        },
        "esp": {
          "state": "ringing"
        }
      }
    }
  ]
}
