{
  "name": "spotpear-full-host-va-intercom-preempt",
  "description": "Spotpear full host profile: SIP incoming call preempts VA response/media and exposes AEC/AFE counters.",
  "steps": [
    {
      "inject_event": {
        "type": "va_start"
      }
    },
    {
      "inject_event": {
        "type": "va_responding"
      }
    },
    {
      "inject_event": {
        "type": "aec_frame",
        "processing_us": 4200
      }
    },
    {
      "inject_event": {
        "type": "afe_frame",
        "latency_us": 8500
      }
    },
    {
      "expect": {
        "voice_assistant": {
          "state": "running",
          "phase": "responding"
        },
        "media": {
          "state": "playing"
        },
        "display": {
          "page": "voice_assistant",
          "status": "va_responding",
          "backlight_on": true
        },
        "aec": {
          "frames": 1,
          "max_processing_us": 4200
        },
        "afe": {
          "frames": 1,
          "max_latency_us": 8500
        }
      }
    },
    {
      "inject_event": {
        "type": "sip_invite",
        "caller": "Casa",
        "callee": "Spotpear",
        "call_id": "Casa-Spotpear-001"
      }
    },
    {
      "expect": {
        "runtime": {
          "device_profile": "spotpear_ball_v2_full_afe",
          "source_profile": "yamls/full-experience/single-bus/spotpear-ball-v2-full-afe.yaml"
        },
        "intercom": {
          "state": "ringing",
          "caller": "Casa"
        },
        "voice_assistant": {
          "state": "idle",
          "phase": "idle"
        },
        "media": {
          "state": "paused"
        },
        "display": {
          "page": "intercom",
          "status": "intercom_ringing"
        },
        "audio": {
          "owner": "intercom"
        }
      }
    }
  ]
}
